# Files excluded from the wp.org build. The plugin is self-contained; after
# `composer install --no-dev` /vendor holds only the Composer autoloader, which
# ships so the optimized classmap is available at runtime.
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
