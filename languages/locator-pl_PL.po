#. Plugin Name of the plugin
#: locator.php
msgid "Locator - Store Locator for WooCommerce"
msgstr "Locator - Wyszukiwarka sklepów dla WooCommerce"

#. Plugin URI of the plugin
#: locator.php
msgid "https://plogins.com/locator/"
msgstr "https://plogins.com/locator/"

#. Description of the plugin
#: locator.php
msgid "Show your physical store locations with a searchable list customers can filter by area."
msgstr "Pokaż lokalizacje swoich sklepów stacjonarnych na przeszukiwalnej liście, którą klienci mogą filtrować według obszaru."

#. Author of the plugin
#: locator.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: locator.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#. translators: 1: Required PHP version, 2: Current PHP version
#: locator.php:57
#, php-format
msgid "Locator requires PHP %1$s or higher. You are running PHP %2$s."
msgstr "Wtyczka Locator wymaga PHP %1$s lub nowszego. Używasz PHP %2$s."

#: locator.php:76
msgid "Locator requires WooCommerce to be installed and activated."
msgstr "Wtyczka Locator wymaga zainstalowanej i aktywnej wtyczki WooCommerce."

#: src/Admin/Settings.php:62
msgid "Locator — Store Locator"
msgstr "Locator — Wyszukiwarka sklepów"

#: src/Admin/Settings.php:63
msgid "Store Locator"
msgstr "Wyszukiwarka sklepów"

#: src/Admin/Settings.php:98
msgid "Address"
msgstr "Adres"

#: src/Admin/Settings.php:99
#: src/PostType/StoreLocation.php:160
#: templates/locator-list.php:94
msgid "Opening hours"
msgstr "Godziny otwarcia"

#: src/Admin/Settings.php:100
#: src/PostType/StoreLocation.php:112
#: src/PostType/StoreLocation.php:159
msgid "Phone"
msgstr "Telefon"

#: src/Admin/Settings.php:107
msgid "Show customers where to find you"
msgstr "Pokaż klientom, gdzie Cię znaleźć"

#: src/Admin/Settings.php:109
msgid "Add your physical stores under WooCommerce → Store Locations, then place the shortcode below on any page to render a searchable, accessible directory your customers can filter by city, postcode or name."
msgstr "Dodaj swoje sklepy stacjonarne w WooCommerce → Lokalizacje sklepów, a następnie umieść poniższy shortcode na dowolnej stronie, aby wyświetlić przeszukiwalny, dostępny katalog, który klienci mogą filtrować według miasta, kodu pocztowego lub nazwy."

#. translators: %s: the [locator] shortcode wrapped in <code>.
#: src/Admin/Settings.php:115
#, php-format
msgid "Add the %s shortcode to a page to display your locations."
msgstr "Dodaj shortcode %s do strony, aby wyświetlić swoje lokalizacje."

#: src/Admin/Settings.php:126
msgid "Display"
msgstr "Wyświetlanie"

#: src/Admin/Settings.php:130
msgid "Search box"
msgstr "Pole wyszukiwania"

#: src/Admin/Settings.php:136
msgid "Show the search box above the results."
msgstr "Pokaż pole wyszukiwania nad wynikami."

#: src/Admin/Settings.php:139
msgid "Visitors can instantly filter locations by city, postcode or name. Filtering happens in the browser — no data leaves the page."
msgstr "Odwiedzający mogą natychmiast filtrować lokalizacje według miasta, kodu pocztowego lub nazwy. Filtrowanie odbywa się w przeglądarce — żadne dane nie opuszczają strony."

#: src/Admin/Settings.php:148
msgid "Fields shown on each card"
msgstr "Pola wyświetlane na każdej karcie"

#: src/Admin/Settings.php:150
msgid "The store name is always shown. Pick which extra details appear beneath it."
msgstr "Nazwa sklepu jest zawsze widoczna. Wybierz, które dodatkowe informacje mają pojawić się pod nią."

#: src/Admin/Settings.php:155
#: src/Admin/Settings.php:159
msgid "Visible fields"
msgstr "Widoczne pola"

